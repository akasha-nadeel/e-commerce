# --- Shopify Storefront API (headless catalog + cart) ---
# Copy this file to `.env.local` and fill in real values.
#
# In Shopify admin: Settings -> Apps and sales channels -> Develop apps ->
# create an app -> Configure Storefront API scopes -> Install -> copy the
# "Storefront API access token" (this token is public-safe / read-only).

# Your store domain, e.g. golden-egal.myshopify.com (NOT the custom domain).
SHOPIFY_STORE_DOMAIN=

# Storefront API access token (public). Kept server-side (not NEXT_PUBLIC_).
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Storefront API version — quarterly (YYYY-MM). Use a currently supported one.
SHOPIFY_API_VERSION=2025-10
